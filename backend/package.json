{
  "name": "expressbymysql",
  "version": "1.0.0",
  "description": "",
  "main": "app.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node app.js",
    "dev": "NODE_ENV=development node app.js",
    "prod": "NODE_ENV=production node app.js",
    "init-db": "node init-database.js",
    "init-admin": "node init-admin.js",
    "setup": "node setup.js",
    "db:migrate": "sequelize-cli db:migrate --config ./config/config.js --migrations-path ./migrations",
    "db:migrate:undo": "sequelize-cli db:migrate:undo --config ./config/config.js --migrations-path ./migrations",
    "db:migrate:status": "sequelize-cli db:migrate:status --config ./config/config.js --migrations-path ./migrations",
    "db:seed-hourly": "node ./scripts/seed-hourly-data.js",
    "deploy:init": "node scripts/init-production-db.js",
    "deploy:prod": "node scripts/deploy-production.js",
    "postinstall": "npm run db:migrate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^16.4.5",
    "bcryptjs": "^2.4.3",
    "express": "^4.17.1",
    "jsonwebtoken": "^9.0.2",
    "method-override": "^3.0.0",
    "multer": "^2.0.2",
    "mysql2": "^3.14.3",
    "sequelize": "^6.37.7"
  },
  "devDependencies": {
    "sequelize-cli": "^6.6.3"
  }
}
